# ───────────── Database (Postgres / Supabase) ─────────────
DB_HOST=your-db-host
DB_PORT=5432
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password
DB_NAME=postgres

# ───────────── Mật khẩu xem toàn bộ task ở trang chủ ─────────────
# Đổi giá trị này sẽ buộc tất cả thiết bị nhập lại mật khẩu.
# Nếu để trống → trang chủ KHÔNG bị khoá (fallback an toàn).
APP_PASSWORD=change-me

# ───────────── (Tuỳ chọn) Domain production cố định ─────────────
# Dùng cho link chia sẻ + ảnh Open Graph (Messenger/Zalo preview).
# Nếu không set, sẽ tự lấy VERCEL_PROJECT_PRODUCTION_URL trên Vercel.
# NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
